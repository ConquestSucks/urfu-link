{
  "name": "@urfu-link/client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm exec expo start",
    "start:tunnel": "pnpm exec expo start --tunnel",
    "start:localhost": "pnpm exec expo start --localhost",
    "android": "pnpm exec expo start --android",
    "ios": "pnpm exec expo start --ios",
    "web": "pnpm exec expo start --web",
    "web:local": "cross-env EXPO_PUBLIC_API_URL=http://localhost:5080 EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080 pnpm exec expo start --web --port 3000",
    "web:build": "pnpm exec expo export --platform web",
    "typecheck": "pnpm exec tsc --noEmit",
    "doctor": "pnpm exec expo doctor"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.7",
    "@react-navigation/native": "^7.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@urfu-link/api-client": "workspace:*",
    "@urfu-link/ui": "workspace:*",
    "expo": "~55.0.9",
    "expo-auth-session": "^55.0.12",
    "expo-constants": "~55.0.9",
    "expo-crypto": "^55.0.12",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-image-picker": "^55.0.16",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.2",
    "phosphor-react-native": "^3.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "rn-emoji-keyboard": "^1.7.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@expo/ngrok": "^4.1.0",
    "@types/node": "^24.10.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "^19.1.11",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
