{
  "name": "@urfu-link/client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm exec expo start",
    "start:tunnel": "pnpm exec expo start --tunnel",
    "start:localhost": "pnpm exec expo start --localhost",
    "android": "pnpm exec expo start --android",
    "ios": "pnpm exec expo start --ios",
    "web": "pnpm exec expo start --web",
    "web:local": "cross-env EXPO_PUBLIC_API_URL=http://localhost:5080 EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080 pnpm exec expo start --web --port 3000",
    "web:build": "pnpm exec expo export --platform web",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "typecheck": "pnpm exec tsc --noEmit",
    "doctor": "pnpm exec expo doctor"
  },
  "dependencies": {
    "@expo/dom-webview": "^56.0.5",
    "@expo/metro-runtime": "~56.0.11",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.90.21",
    "@urfu-link/api-client": "workspace:*",
    "@urfu-link/ui": "workspace:*",
    "expo": "~56.0.3",
    "expo-audio": "~56.0.10",
    "expo-auth-session": "^56.0.11",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-crypto": "^56.0.3",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.8",
    "expo-image-picker": "^56.0.12",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.2",
    "phosphor-react-native": "^3.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css-interop": "0.2.3",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "rn-emoji-keyboard": "^1.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "msw": "^2.14.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  }
}
