{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Auth": {
        "Authority": "http://keycloak:8080/realms/urfu-link",
        "Audience": "urfu-link-api"
    },
    "Kafka": {
        "BootstrapServers": "kafka:29092",
        "ConsumerGroup": "media-service-v1",
        "ConsumerTopic": "urfu.media.events.v1"
    },
    "Observability": {
        "Otlp": {
            "Endpoint": "http://otel-collector:4317"
        }
    },
    "ConnectionStrings": {
        "Primary": "Host=postgres;Port=5432;Database=media_db;Username=media;Password=media;GSS Encryption Mode=Disable"
    },
    "Infrastructure": {
        "Redis": {
            "Configuration": "redis:6379"
        }
    },
    "Storage": {
        "Endpoint": "http://minio:9000",
        "PublicEndpoint": "http://localhost:9000",
        "AccessKey": "minio",
        "SecretKey": "minio123",
        "PrivateBucket": "media-private",
        "PublicBucket": "media-public",
        "UploadUrlTtl": "00:15:00",
        "DownloadUrlTtl": "00:15:00",
        "UploadSessionTtl": "00:30:00"
    },
    "MediaLimits": {
        "Image":    { "MaxSizeBytes": 20971520 },
        "Video":    { "MaxSizeBytes": 104857600 },
        "Voice":    { "MaxSizeBytes": 10485760 },
        "Audio":    { "MaxSizeBytes": 52428800 },
        "Document": { "MaxSizeBytes": 104857600 }
    },
    "Retention": {
        "SoftDeleteTtl": "30.00:00:00",
        "SweepInterval": "1.00:00:00",
        "BatchLimit": 500
    }
}
