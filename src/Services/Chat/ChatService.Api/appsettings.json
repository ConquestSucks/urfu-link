{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Auth": {
        "Authority": "http://keycloak:8080/realms/urfu-link",
        "Audience": "urfu-link-api"
    },
    "Kafka": {
        "BootstrapServers": "kafka:9092"
    },
    "Observability": {
        "Otlp": {
            "Endpoint": "http://otel-collector:4317"
        }
    },
    "ConnectionStrings": {
        "Primary": "mongodb://mongo:27017/chat_db"
    },
    "Infrastructure": {
        "Redis": {
            "Configuration": "redis:6379"
        }
    },
    "GrpcClients": {
        "MediaService": {
            "Address": "http://media-service:8080"
        }
    },
    "Chat": {
        "EditTtlHours": 48,
        "DeleteForEveryoneTtlHours": 48,
        "MaxPinnedMessages": 5,
        "MaxForwardedMessages": 50,
        "AllowedReactionEmojis": [],
        "MaxReactionEmojiLength": 16,
        "MaxMentionsPerMessage": 50
    }
}
