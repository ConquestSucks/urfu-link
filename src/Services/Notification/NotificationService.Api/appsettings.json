{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Authority": "http://keycloak:8080/realms/urfu-link",
    "Audience": "urfu-link-api"
  },
  "ConnectionStrings": {
    "Primary": "Host=postgres;Port=5432;Database=notification_db;Username=notification;Password=notification;GSS Encryption Mode=Disable"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "ConsumerGroup": "notification-service-v1",
    "ConsumerTopic": "urfu.notification.events.v1"
  },
  "Observability": {
    "Otlp": {
      "Endpoint": "http://otel-collector:4317"
    }
  },
  "Infrastructure": {
    "Redis": {
      "Configuration": "redis:6379"
    }
  },
  "Notification": {
    "Push": {
      "Provider": "real",
      "Fcm": { "ServiceAccountPath": "/secrets/fcm-service-account.json", "ProjectId": "" },
      "Apns": {
        "P8KeyPath": "/secrets/apns-key.p8",
        "KeyId": "",
        "TeamId": "",
        "BundleId": "ru.urfu.urfulink",
        "IsProduction": true
      }
    },
    "Smtp": {
      "Host": "smtp.urfu.ru",
      "Port": 587,
      "EnableStartTls": true,
      "Username": "",
      "Password": "",
      "From": "noreply@urfu-link.ghjc.ru",
      "FromDisplayName": "UrFU Link"
    },
    "DefaultLocale": "ru-RU",
    "SupportedLocales": [ "ru-RU", "en-US" ],
    "RetentionDays": 90
  },
  "PushDispatcher": { "PollInterval": "00:00:02", "BatchSize": 64, "MaxAttempts": 5 },
  "EmailDispatcher": { "PollInterval": "00:00:05", "BatchSize": 32, "MaxAttempts": 5 },
  "InAppDispatcher": { "PollInterval": "00:00:01", "BatchSize": 128, "MaxAttempts": 3 },
  "NotificationOutbox": {
    "PollInterval": "00:00:02",
    "BatchSize": 64,
    "InitialBackoff": "00:00:02",
    "MaxBackoff": "00:05:00"
  },
  "UserService": { "GrpcEndpoint": "http://user-service:8081" },
  "PresenceService": { "GrpcEndpoint": "http://presence-service:8081" },
  "Idempotency": { "Retention": "1.00:00:00" }
}
