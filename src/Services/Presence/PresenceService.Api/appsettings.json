{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Auth": {
        "Authority": "http://keycloak:8080/realms/urfu-link",
        "Audience": "urfu-link-api"
    },
    "Kafka": {
        "BootstrapServers": "kafka:29092",
        "ConsumerGroup": "presence-privacy-projection-v1",
        "ConsumerTopic": "urfu.user.events.v1"
    },
    "Observability": {
        "Otlp": {
            "Endpoint": "http://otel-collector:4317"
        }
    },
    "ConnectionStrings": {
        "Primary": "Host=postgres;Port=5432;Database=presence_db;Username=presence;Password=presence;GSS Encryption Mode=Disable"
    },
    "Infrastructure": {
        "Redis": {
            "Configuration": "redis:6379"
        }
    }
}
